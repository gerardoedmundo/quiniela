<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Pase de Lista - Preparatoria</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      background: #f4f6f9;
    }
    h1 {
      text-align: center;
    }
    .container {
      max-width: 900px;
      margin: auto;
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    input, button {
      padding: 10px;
      margin: 5px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 10px;
      text-align: center;
    }
    th {
      background-color: #007BFF;
      color: white;
    }
    .present { background-color: #c8e6c9; }
    .absent { background-color: #ffcdd2; }
  </style>
</head>
<body>

<div class="container">
  <h1>Pase de Lista</h1>

  <input type="text" id="studentName" placeholder="Nombre del alumno">
  <button onclick="addStudent()">Agregar alumno</button>
  <button onclick="saveAttendance()">Guardar asistencia</button>
  <button onclick="exportCSV()">Exportar a Excel</button>

  <table id="attendanceTable">
    <thead>
      <tr>
        <th>#</th>
        <th>Nombre</th>
        <th>Asistencia</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>
</div>

<script>
let students = JSON.parse(localStorage.getItem("students")) || [];

function renderTable() {
  const tbody = document.querySelector("#attendanceTable tbody");
  tbody.innerHTML = "";

  students.forEach((student, index) => {
    let row = document.createElement("tr");

    row.innerHTML = `
      <td>${index + 1}</td>
      <td>${student.name}</td>
      <td>
        <button onclick="markAttendance(${index}, 'present')">✔</button>
        <button onclick="markAttendance(${index}, 'absent')">✘</button>
      </td>
    `;

    if (student.status === "present") row.classList.add("present");
    if (student.status === "absent") row.classList.add("absent");

    tbody.appendChild(row);
  });
}

function addStudent() {
  const nameInput = document.getElementById("studentName");
  const name = nameInput.value.trim();

  if (name === "") {
    alert("Ingresa un nombre");
    return;
  }

  students.push({ name: name, status: "" });
  nameInput.value = "";
  renderTable();
}

function markAttendance(index, status) {
  students[index].status = status;
  renderTable();
}

function saveAttendance() {
  localStorage.setItem("students", JSON.stringify(students));
  alert("Asistencia guardada");
}

function exportCSV() {
  let csv = "Numero,Nombre,Asistencia\n";

  students.forEach((s, i) => {
    csv += `${i+1},${s.name},${s.status}\n`;
  });

  const blob = new Blob([csv], { type: "text/csv" });
  const url = window.URL.createObjectURL(blob);

  const a = document.createElement("a");
  a.href = url;
  a.download = "asistencia.csv";
  a.click();
}

renderTable();
</script>

</body>
</html>
